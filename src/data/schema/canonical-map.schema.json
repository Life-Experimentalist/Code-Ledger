{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codeledger.vkrishna04.me/data/schema/canonical-map.schema.json",
  "$comment": "Schema for the canonical map of coding problems",
  "type": "object",
  "items": {
    "type": "object",
    "properties": {
      "canonicalId": {
        "type": "string"
      },
      "canonicalTitle": {
        "type": "string"
      },
      "topic": {
        "type": "string"
      },
      "difficulty": {
        "type": "string",
        "enum": [
          "Easy",
          "Medium",
          "Hard"
        ]
      },
      "pattern": {
        "type": "string"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "aliases": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      }
    },
    "required": [
      "canonicalId",
      "canonicalTitle",
      "topic",
      "difficulty"
    ]
  }
}