# Environment variables for Cloudflare Worker
# Copy these values into your Cloudflare Worker environment (Settings -> Variables)

# For GitHub App (recommended for server-side repo commits)
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY="" # PEM private key content, newline escaped or stored as a secret
GITHUB_APP_WEBHOOK_SECRET="" # webhook secret to validate events

# For OAuth App fallback (the worker contains simple OAuth endpoints)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Telemetry and other endpoints
TELEMETRY_ENDPOINT="https://counter.vkrishna04.me"

# Admin token used to protect the canonical upload endpoint
# Set a strong random value and add it as a Worker secret: CANONICAL_UPLOAD_TOKEN
CANONICAL_UPLOAD_TOKEN=""

# Note: Create a KV namespace named (binding) `CANONICAL_MAP` and bind it to the Worker.
# You can upload the initial canonical map into KV or use the admin endpoint to push updates.
