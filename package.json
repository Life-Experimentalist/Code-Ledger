{
  "name": "codeledger",
  "version": "1.0.0",
  "description": "CodeLedger is a universal browser extension that atomically commits your solved Data Structures and Algorithms problems (from LeetCode, GeeksForGeeks, etc.) to your own GitHub repository.",
  "author": "CodeLedger Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vkrishna04/codeledger.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node dev/run-dev.js",
    "start": "tsx server.ts",
    "build:css": "npx @tailwindcss/cli -i src/index.css -o src/ui/styles/compiled.css --minify",
    "build:dist": "node dev/build.js",
    "build": "npm run build:css && npm run build:dist",
    "watch": "node dev/watch.js",
    "package": "node dev/package.js",
    "clean": "node dev/clean.js",
    "deploy:worker": "cd worker && npx wrangler pages deploy public",
    "lint": "tsc --noEmit",
    "validate:openapi": "node dev/validate-openapi.js"
  },
  "dependencies": {
    "@google/genai": "^1.31.0",
    "chart.js": "^4.4.8",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "htm": "^3.1.1",
    "lucide-react": "^0.546.0",
    "preact": "^10.26.4",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/chrome": "^0.0.308",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "adm-zip": "^0.5.17",
    "bestzip": "^2.2.1",
    "esbuild": "^0.25.1",
    "js-yaml": "^4.1.0",
    "nodemon": "^3.1.9",
    "octokit": "^4.0.0",
    "puppeteer": "^24.15.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "wrangler": "^4.85.0"
  }
}
