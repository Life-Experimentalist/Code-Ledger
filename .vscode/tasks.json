{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch CSS + Extension",
      "type": "shell",
      "command": "npm run watch",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "tailwind",
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+): (error|warning): (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Rebuilding",
          "endsPattern": "^Done"
        }
      }
    },
    {
      "label": "Build CSS",
      "type": "shell",
      "command": "npm run build:css",
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Build (CSS + Package)",
      "type": "shell",
      "command": "npm run build",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Type Check",
      "type": "shell",
      "command": "npm run lint",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Deploy Worker",
      "type": "shell",
      "command": "npm run deploy:worker",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Package Chrome Extension",
      "type": "shell",
      "command": "node dev/package-chrome.js",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Smoke Test Worker",
      "type": "shell",
      "command": "curl -sf https://codeledger.vkrishna04.me/api/health",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
